@model List<RealEstate_Admin.Models.PropertyModel>

<main id="main" class="main">
    <div class="pagetitle">
        <h1>Property Management</h1>
        <nav>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item active">Properties</li>
            </ol>
        </nav>
    </div>

    <section class="section">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body py-3">
                        <!-- Header with Search and Add Button -->
                        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                            <div class="search-box position-relative">
                                <input type="text" id="searchInput" class="form-control" placeholder="Search properties by title, location..." style="padding-left: 40px; width: 300px;" />
                                <i class="bi bi-search position-absolute" style="left: 12px; top: 50%; transform: translateY(-50%); color: #6c757d;"></i>
                            </div>
                            <a asp-controller="Property" asp-action="AddProperty" class="btn btn-primary d-flex align-items-center gap-2">
                                <i class="bi bi-plus-circle"></i> Add Property
                            </a>
                        </div>

                        <!-- Filter Pills -->
                        <div class="d-flex gap-2 mb-4 flex-wrap">
                            <button class="btn btn-sm btn-outline-secondary filter-btn active" data-filter="all">All</button>
                            <button class="btn btn-sm btn-outline-success filter-btn" data-filter="Available">Available</button>
                            <button class="btn btn-sm btn-outline-warning filter-btn" data-filter="Pending">Pending</button>
                            <button class="btn btn-sm btn-outline-danger filter-btn" data-filter="Sold">Sold</button>
                            <span class="mx-2 text-muted">|</span>
                            <button class="btn btn-sm btn-outline-primary filter-btn" data-filter="Sell">For Sale</button>
                            <button class="btn btn-sm btn-outline-info filter-btn" data-filter="Rent">For Rent</button>
                        </div>

                        <!-- Properties Grid -->
                        @if (Model != null && Model.Count > 0)
                        {
                            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4" id="propertyGrid">
                                @foreach (var property in Model)
                                {
                                    <div class="col property-card" data-title="@property.Title.ToLower()" data-location="@property.Location.ToLower()" data-status="@property.Status" data-category="@property.Category">
                                        <div class="card h-100 shadow-sm property-card-item">
                                            <!-- Image Section -->
                                            <div class="position-relative">
                                                @if (property.Images != null && property.Images.Any())
                                                {
                                                    <img class="card-img-top"
                                                         src="@(property.Images.OrderBy(i => i.DisplayOrder).FirstOrDefault()?.ImagePath ?? "/images/no-image.jpg")"
                                                         alt="@property.Title"
                                                         style="height: 200px; object-fit: cover;" />
                                                }
                                                else
                                                {
                                                    <div class="bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                                        <i class="bi bi-image text-muted" style="font-size: 3rem;"></i>
                                                    </div>
                                                }
                                                
                                                <!-- Category Badge -->
                                                <span class="position-absolute top-0 start-0 m-2 badge bg-@GetCategoryBadgeClass(property.Category)">
                                                    @property.Category
                                                </span>

                                                <!-- Status Badge -->
                                                <span class="position-absolute top-0 end-0 m-2 badge bg-@GetStatusBadgeClass(property.Status)">
                                                    @property.Status
                                                </span>

                                                <!-- Property Type Badge -->
                                                <span class="position-absolute bottom-0 start-0 m-2 badge bg-secondary">
                                                    <i class="bi bi-building"></i> @property.PropertyType
                                                </span>
                                            </div>

                                            <!-- Card Body -->
                                            <div class="card-body p-3">
                                                <h5 class="card-title text-truncate mb-1" title="@property.Title">@property.Title</h5>
                                                
                                                <p class="text-muted small mb-2">
                                                    <i class="bi bi-geo-alt"></i> @property.Location
                                                </p>

                                                <div class="d-flex justify-content-between align-items-center mb-3">
                                                    <span class="fw-bold text-primary" style="font-size: 1.1rem;">
                                                        @property.Price.ToString("C0")
                                                    </span>
                                                    <span class="badge bg-light text-dark">
                                                        <i class="bi bi-arrows-angle-expand"></i> @property.Area sqft
                                                    </span>
                                                </div>

                                                <!-- Property Features -->
                                                <div class="d-flex justify-content-between text-muted small mb-3 pb-3 border-bottom">
                                                    <span><i class="bi bi-door-open"></i> @property.Bedrooms Beds</span>
                                                    <span><i class="bi bi-droplet"></i> @property.Bathrooms Baths</span>
                                                    <span><i class="bi bi-tags"></i> @property.PropertyType</span>
                                                </div>
                                            </div>

                                            <!-- Card Footer -->
                                            <div class="card-footer bg-white border-top-0 d-flex justify-content-between">
                                                <a asp-controller="Property" asp-action="AddProperty" asp-route-PropertyId="@property.PropertyId" 
                                                   class="btn btn-sm btn-success">
                                                    <i class="bi bi-pencil"></i> Edit
                                                </a>
                                                <span class="text-muted small align-self-center">
                                                    Listed: @property.ListedDate.ToString("MMM dd, yyyy")
                                                </span>
                                                <form method="post" asp-controller="Property" asp-action="DeleteProperty" onsubmit="return confirmDelete('@property.Title');">
                                                    <input type="hidden" name="propertyId" value="@property.PropertyId" />
                                                    <button type="submit" class="btn btn-sm btn-danger">
                                                        <i class="bi bi-trash"></i> Delete
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-house-x" style="font-size: 4rem; color: #ccc;"></i>
                                <h4 class="mt-3 text-muted">No Properties Found</h4>
                                <p class="text-muted">Add your first property to get started.</p>
                                <a asp-controller="Property" asp-action="AddProperty" class="btn btn-primary">
                                    <i class="bi bi-plus-circle"></i> Add Property
                                </a>
                            </div>
                        }

                        <!-- No Results Message (Hidden by default) -->
                        <div id="noResults" class="text-center py-5" style="display: none;">
                            <i class="bi bi-search" style="font-size: 4rem; color: #ccc;"></i>
                            <h4 class="mt-3 text-muted">No Matching Properties</h4>
                            <p class="text-muted">Try adjusting your search or filters.</p>
                            <button id="clearFilters" class="btn btn-secondary">Clear Filters</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong id="propertyToDelete"></strong>?</p>
                <p class="text-muted">This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
            </div>
        </div>
    </div>
</div>

@functions {
    string GetStatusBadgeClass(string status)
    {
        return status?.ToLower() switch
        {
            "available" => "success",
            "sold" => "danger",
            "pending" => "warning",
            "active" => "success",
            "inactive" => "secondary",
            _ => "secondary"
        };
    }

    string GetCategoryBadgeClass(string category)
    {
        return category?.ToLower() switch
        {
            "sell" => "primary",
            "buy" => "info",
            "rent" => "warning",
            _ => "secondary"
        };
    }
}

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    // Search Functionality
    $('#searchInput').on('keyup', function() {
        const searchTerm = $(this).val().toLowerCase();
        
        $('.property-card').each(function() {
            const title = $(this).data('title');
            const location = $(this).data('location');
            
            if (title.includes(searchTerm) || location.includes(searchTerm)) {
                $(this).show();
            } else {
                $(this).hide();
            }
        });
        
        toggleNoResults();
    });

    // Filter Pills Functionality
    $('.filter-btn').on('click', function() {
        const filter = $(this).data('filter');
        
        // Update active state
        $('.filter-btn').removeClass('active');
        $(this).addClass('active');
        
        // Filter cards
        if (filter === 'all') {
            $('.property-card').show();
        } else {
            $('.property-card').each(function() {
                const status = $(this).data('status');
                const category = $(this).data('category');
                
                if (status === filter || category === filter) {
                    $(this).show();
                } else {
                    $(this).hide();
                }
            });
        }
        
        toggleNoResults();
    });

    // Clear Filters
    $('#clearFilters').on('click', function() {
        $('#searchInput').val('');
        $('.filter-btn').removeClass('active');
        $('.filter-btn[data-filter="all"]').addClass('active');
        $('.property-card').show();
        toggleNoResults();
    });

    // Toggle No Results
    function toggleNoResults() {
        const visibleCards = $('.property-card:visible').length;
        if (visibleCards === 0) {
            $('#propertyGrid').hide();
            $('#noResults').show();
        } else {
            $('#propertyGrid').show();
            $('#noResults').hide();
        }
    }

    // Confirm Delete
    function confirmDelete(propertyTitle) {
        $('#propertyToDelete').text(propertyTitle);
        $('#deleteModal').modal('show');
        return false;
    }

    // Handle Confirm Delete Button
    $('#confirmDeleteBtn').on('click', function() {
        $('#deleteModal').modal('hide');
        // The form will be submitted via the original onclick handler
    });
</script>

<style>
    .property-card-item {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    
    .property-card-item:hover {
        transform: translateY(-5px);
        box-shadow: 0 4px 15px rgba(0,0,0,0.1) !important;
    }
    
    .filter-btn.active {
        background-color: #0d6efd;
        color: white;
        border-color: #0d6efd;
    }
    
    .search-box input:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.1rem rgba(13, 110, 253, 0.25);
    }
    
    .badge {
        font-weight: 500;
    }
</style>