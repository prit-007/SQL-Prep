@model RealEstate_Admin.Models.PropertyModel

<main id="main" class="main">
    <section class="section">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h2 class="mb-0">
                                <i class="bi bi-@(Model.PropertyId > 0 ? "pencil-square" : "plus-circle") me-2"></i>
                                @(Model.PropertyId > 0 ? "Edit Property" : "Add New Property")
                            </h2>
                            <a asp-controller="Property" asp-action="PropertyList" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Back to List
                            </a>
                        </div>

                        <form asp-action="SaveProperty" asp-controller="Property" method="post" enctype="multipart/form-data" id="propertyForm">
                            @Html.HiddenFor(x => x.PropertyId)

                            <!-- Display Existing Images if Editing -->
                            @if (Model.PropertyId > 0 && Model.Images != null && Model.Images.Any())
                            {
                                <div class="alert alert-info d-flex align-items-center mb-4" role="alert">
                                    <i class="bi bi-info-circle me-2"></i>
                                    <div>
                                        <strong>Editing Property:</strong> You can manage existing images below. 
                                        New images will be added to the existing ones. Remove images you want to delete.
                                    </div>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label fw-bold">Current Images <span class="text-muted">(click to remove)</span></label>
                                    <div class="row g-3" id="existingImages">
                                        @{
                                            var primarySet = false;
                                            foreach (var img in Model.Images.OrderBy(i => i.DisplayOrder))
                                            {
                                                var isPrimary = !primarySet;
                                                primarySet = true;
                                                <div class="col-6 col-md-4 col-lg-3 existing-image-item" data-image-id="@img.ImageId">
                                                    <div class="card h-100 border-0 shadow-sm position-relative">
                                                        <img src="@img.ImagePath" class="card-img-top" alt="Property Image" style="height: 150px; object-fit: cover;" />
                                                        @if (isPrimary)
                                                        {
                                                            <span class="position-absolute top-0 start-0 m-2 badge bg-primary">Primary</span>
                                                        }
                                                        <div class="card-body p-2 text-center">
                                                            <div class="form-check d-flex justify-content-center align-items-center">
                                                                <input type="radio" name="PrimaryImage" 
                                                                       class="form-check-input me-1" 
                                                                       value="@img.ImageId" 
                                                                       @(isPrimary ? "checked" : "") />
                                                                <label class="form-check-label small text-muted">Set as Primary</label>
                                                            </div>
                                                            <button type="button" class="btn btn-sm btn-outline-danger w-100 mt-2" 
                                                                    onclick="removeImage(@img.ImageId, '@img.ImageName')">
                                                                <i class="bi bi-trash"></i> Remove
                                                            </button>
                                                            <input type="hidden" name="ImagesToRemove" id="imagesToRemove" value="" />
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                            }

                            <div class="row">
                                <!-- Left Column - Property Details -->
                                <div class="col-lg-7">
                                    <h5 class="mb-3 text-muted border-bottom pb-2">Property Details</h5>

                                    <div class="mb-3">
                                        <label for="Title" class="form-label">Property Title <span class="text-danger">*</span></label>
                                        <input type="text" asp-for="Title" class="form-control" placeholder="e.g., Modern Downtown Apartment" />
                                    </div>

                                    <div class="mb-3">
                                        <label for="Description" class="form-label">Description</label>
                                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Describe the property..."></textarea>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label for="Price" class="form-label">Price ($) <span class="text-danger">*</span></label>
                                            <input type="number" asp-for="Price" class="form-control" placeholder="250000" />
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label for="Area" class="form-label">Area (sq ft) <span class="text-danger">*</span></label>
                                            <input type="number" asp-for="Area" class="form-control" placeholder="1200" />
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="Location" class="form-label">Location <span class="text-danger">*</span></label>
                                        <input type="text" asp-for="Location" class="form-control" placeholder="e.g., New York, NY" />
                                    </div>

                                    <div class="row">
                                        <div class="col-md-4 mb-3">
                                            <label for="Bedrooms" class="form-label">Bedrooms</label>
                                            <input type="number" asp-for="Bedrooms" class="form-control" placeholder="2" />
                                        </div>
                                        <div class="col-md-4 mb-3">
                                            <label for="Bathrooms" class="form-label">Bathrooms</label>
                                            <input type="number" asp-for="Bathrooms" class="form-control" placeholder="2" />
                                        </div>
                                        <div class="col-md-4 mb-3">
                                            <label for="Status" class="form-label">Status</label>
                                            <select asp-for="Status" class="form-select">
                                                <option value="Available">Available</option>
                                                <option value="Sold">Sold</option>
                                                <option value="Pending">Pending</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="Amenities" class="form-label">Amenities</label>
                                        <textarea asp-for="Amenities" class="form-control" rows="2" placeholder="Gym, Pool, Parking, etc."></textarea>
                                        <small class="text-muted">Separate amenities with commas</small>
                                    </div>
                                </div>

                                <!-- Right Column - Type, Category & Images -->
                                <div class="col-lg-5">
                                    <h5 class="mb-3 text-muted border-bottom pb-2">Property Classification</h5>

                                    <!-- Property Type -->
                                    <div class="mb-4">
                                        <label class="form-label fw-bold">Property Type</label>
                                        <div class="btn-group w-100" role="group">
                                            <input type="radio" class="btn-check" asp-for="PropertyTypeId" id="House" value="1" />
                                            <label class="btn btn-outline-primary" for="House">
                                                <i class="bi bi-house"></i> House
                                            </label>

                                            <input type="radio" class="btn-check" asp-for="PropertyTypeId" id="Apartment" value="2" />
                                            <label class="btn btn-outline-primary" for="Apartment">
                                                <i class="bi bi-building"></i> Apartment
                                            </label>

                                            <input type="radio" class="btn-check" asp-for="PropertyTypeId" id="Commercial" value="3" />
                                            <label class="btn btn-outline-primary" for="Commercial">
                                                <i class="bi bi-briefcase"></i> Commercial
                                            </label>
                                        </div>
                                    </div>

                                    <!-- Category -->
                                    <div class="mb-4">
                                        <label class="form-label fw-bold">Category</label>
                                        <div class="btn-group w-100" role="group">
                                            <input type="radio" class="btn-check" asp-for="Category" id="Sell" value="Sell" />
                                            <label class="btn btn-outline-success" for="Sell">
                                                <i class="bi bi-tag"></i> For Sale
                                            </label>

                                            <input type="radio" class="btn-check" asp-for="Category" id="Rent" value="Rent" />
                                            <label class="btn btn-outline-warning" for="Rent">
                                                <i class="bi bi-currency-dollar"></i> For Rent
                                            </label>
                                        </div>
                                    </div>

                                    <!-- Upload New Images -->
                                    <div class="mb-4">
                                        <label class="form-label fw-bold">
                                            <i class="bi bi-cloud-upload me-1"></i> Add More Images
                                        </label>
                                        <div class="upload-area border border-2 border-dashed rounded p-4 text-center bg-light">
                                            <input type="file"
                                                   asp-for="ImageFiles"
                                                   class="form-control"
                                                   multiple
                                                   accept="image/*"
                                                   id="newImagesInput" />
                                            <small class="text-muted d-block mt-2">
                                                <i class="bi bi-info-circle"></i> Select multiple images (jpg, png, jpeg)
                                            </small>
                                        </div>

                                        <!-- Preview New Images -->
                                        <div class="mt-3" id="newImagePreview" style="display: none;">
                                            <label class="form-label">New Images Preview:</label>
                                            <div class="row g-2" id="previewGrid"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Form Actions -->
                            <div class="d-flex justify-content-between align-items-center border-top pt-4 mt-4">
                                <a asp-controller="Property" asp-action="PropertyList" class="btn btn-light">
                                    <i class="bi bi-x-lg"></i> Cancel
                                </a>
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn btn-secondary" onclick="resetForm()">
                                        <i class="bi bi-arrow-counterclockwise"></i> Reset
                                    </button>
                                    <button type="submit" class="btn btn-primary btn-lg">
                                        <i class="bi bi-check2-circle"></i> @(Model.PropertyId > 0 ? "Update Property" : "Save Property")
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

<!-- Remove Image Confirmation Modal -->
<div class="modal fade" id="removeImageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-trash"></i> Remove Image</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to remove this image?</p>
                <p class="text-muted small">This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmRemoveBtn">Remove</button>
            </div>
        </div>
    </div>
</div>

<script>
    let imagesToRemove = [];

    // Preview new images when selected
    document.getElementById('newImagesInput').addEventListener('change', function(e) {
        const files = e.target.files;
        const previewGrid = document.getElementById('previewGrid');
        const previewContainer = document.getElementById('newImagePreview');
        
        previewGrid.innerHTML = '';
        
        if (files.length > 0) {
            previewContainer.style.display = 'block';
            
            for (let i = 0; i < files.length; i++) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const col = document.createElement('div');
                    col.className = 'col-4';
                    col.innerHTML = `
                        <div class="position-relative">
                            <img src="${e.target.result}" class="img-fluid rounded" style="height: 80px; object-fit: cover; width: 100%;" />
                            <span class="badge bg-success position-absolute bottom-0 start-0 m-1">New</span>
                        </div>
                    `;
                    previewGrid.appendChild(col);
                };
                reader.readAsDataURL(files[i]);
            }
        } else {
            previewContainer.style.display = 'none';
        }
    });

    // Remove existing image
    function removeImage(imageId, imageName) {
        document.getElementById('propertyToDeleteName').textContent = imageName;
        document.getElementById('removeImageModal').setAttribute('data-image-id', imageId);
        $('#removeImageModal').modal('show');
    }

    // Confirm remove
    document.getElementById('confirmRemoveBtn').addEventListener('click', function() {
        const imageId = document.getElementById('removeImageModal').getAttribute('data-image-id');
        
        // Add to remove list
        imagesToRemove.push(imageId);
        document.getElementById('imagesToRemove').value = imagesToRemove.join(',');
        
        // Hide the card
        document.querySelector(`[data-image-id="${imageId}"]`).style.display = 'none';
        
        $('#removeImageModal').modal('hide');
        
        // Show toast/alert
        showToast('Image marked for removal', 'warning');
    });

    // Reset form
    function resetForm() {
        if (confirm('Are you sure you want to reset all changes?')) {
            document.getElementById('propertyForm').reset();
            document.getElementById('newImagePreview').style.display = 'none';
            document.getElementById('previewGrid').innerHTML = '';
            imagesToRemove = [];
            document.getElementById('imagesToRemove').value = '';
        }
    }

    // Show toast message
    function showToast(message, type) {
        const toast = document.createElement('div');
        toast.className = `toast align-items-center text-white bg-${type === 'warning' ? 'warning' : type} border-0 position-fixed bottom-0 end-0 m-3`;
        toast.setAttribute('role', 'alert');
        toast.setAttribute('data-bs-delay', '2000');
        toast.innerHTML = `
            <div class="d-flex">
                <div class="toast-body">${message}</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        `;
        document.body.appendChild(toast);
        const bsToast = new bootstrap.Toast(toast);
        bsToast.show();
    }

    // Auto-hide alerts
    setTimeout(() => {
        document.querySelectorAll('.alert').forEach(alert => {
            alert.style.display = 'none';
        });
    }, 5000);
</script>

<style>
    .border-dashed {
        border-style: dashed !important;
    }
    
    .upload-area:hover {
        background-color: #f8f9fa !important;
        border-color: #0d6efd !important;
    }
    
    .btn-check:checked + .btn {
        background-color: #0d6efd;
        color: white;
        border-color: #0d6efd;
    }
    
    .existing-image-item {
        transition: opacity 0.3s;
    }
    
    .existing-image-item:hover {
        opacity: 0.8;
    }
</style>